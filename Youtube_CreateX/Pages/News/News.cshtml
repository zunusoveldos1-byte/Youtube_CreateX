@page
@model Youtube_CreateX.Pages.News.NewsModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Новости - Createx</title>
    <link rel="stylesheet" href="~/css/news.css" asp-append-version="true" />
</head>
<body>
    <div class="top-wrapper">
        <header class="header">
            <div class="container">
                <nav class="header__nav">
                    <a asp-page="/Index" class="header__nav-logo-link">
                        <img src="~/img/header/logo(3).svg" asp-append-version="true" alt="Логотип Createx" class="header__nav-logo">
                    </a>
                    <ul class="header__nav-ul">
                        <li><a asp-page="/AboutUs/About" class="header__nav-link">О нас</a></li>
                        <li><a asp-page="/Services/Services" class="header__nav-link">Услуги</a></li>
                        <li><a asp-page="/Work/Work" class="header__nav-link">Работы</a></li>
                        <li><a asp-page="/News/News" class="header__nav-link active">Новости</a></li>
                        <li><a asp-page="/Contacts/Contacts" class="header__nav-link">Контакты</a></li>
                    </ul>
                    <div class="header__nav-contacts">
                        <div class="header__nav-contact">
                            <img src="~/img/header/iPhone(2).svg" asp-append-version="true" alt="Телефон">
                            <div class="contact-text">
                                <div class="label">Позвоните нам</div>
                                <div class="value">(405) 555-0128</div>
                            </div>
                        </div>
                        <div class="header__nav-contact">
                            <img src="~/img/header/Chat(2).svg" asp-append-version="true" alt="Чат">
                            <div class="contact-text">
                                <div class="label">Напишите нам</div>
                                <div class="value">hello@createx.com</div>
                            </div>
                        </div>
                    </div>
                </nav>
            </div>
        </header>

        <section class="hero">
            <div class="container">
                <ul class="breadcrumbs">
                    <li><a asp-page="/Index">Главная</a></li>
                    <li><span>Новости</span></li>
                </ul>
                <h1 class="hero__title">НОВОСТИ</h1>
                <p class="hero__desc">
                    Следите за нашими новостями, советами экспертов и статьями.
                </p>
            </div>
        </section>
    </div>

    <section class="news container">
        <h2 class="news__title">Категории</h2>

        <div class="categories">
            <!-- Ссылка "Все новости" (сбрасывает категорию) -->
            <a asp-page="News"
               asp-route-category=""
               asp-route-pageIndex="1"
               class="categories__btn @(string.IsNullOrEmpty(Model.Category) ? "active" : "")">
                Все новости
            </a>

            <!-- Динамические категории из базы данных -->
            @foreach (var cat in Model.Categories)
            {
                <a asp-page="News"
                   asp-route-category="@cat"
                   asp-route-pageIndex="1"
                   class="categories__btn @(Model.Category == cat ? "active" : "")">
                    @cat
                </a>
            }
        </div>

        <div class="news-grid">
            @foreach (var news in Model.NewsList)
            {
                <article class="card">
                    <div class="card__image">
                        <img src="@(news.ImagePath ?? "/img/no-image.svg")" alt="@news.Title">
                    </div>
                    <div class="card__content">
                        <h3 class="card__title">@news.Title</h3>
                        <div class="card__info">
                            <span>@news.Category</span> |
                            <span>@news.CreatedAt.ToString("dd MMMM yyyy")</span> |
                            <span>0 комментариев</span> <!-- Можно будет добавить позже -->
                        </div>
                        <p class="card__text">@news.Content</p>
                    </div>
                </article>
            }
        </div>

        <!-- Пагинация -->
        @if (Model.TotalPages > 1)
        {
            <div class="pagination">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-page="News"
                       asp-route-category="@Model.Category"
                       asp-route-pageIndex="@i"
                       class="pagination__item @(i == Model.PageIndex ? "active" : "")">
                        @i
                    </a>
                }
                @if (Model.PageIndex < Model.TotalPages)
                {
                    <a asp-page="News"
                       asp-route-category="@Model.Category"
                       asp-route-pageIndex="@(Model.PageIndex + 1)"
                       class="pagination__item pagination__item--next">
                        <img src="~/img/categories/Right.svg" alt="Следующая">
                    </a>
                }
            </div>
        }
    </section>

    <footer class="footer">
        <div class="footer__container">
            <div class="footer__top">
                <div class="footer__column footer__column--info">
                    <div class="footer__brand">
                        <img src="~/img/footer/logo(2).svg" asp-append-version="true" alt="Createx" class="footer__logo">
                        <div class="footer__socials">
                            <a href="#" class="footer__social-link"><img src="~/img/footer/whatsapp.svg" asp-append-version="true" alt="WA"></a>
                            <a href="#" class="footer__social-link"><img src="~/img/footer/Messanger.svg" asp-append-version="true" alt="MS"></a>
                            <a href="#" class="footer__social-link"><img src="~/img/footer/facebook.svg" asp-append-version="true" alt="FB"></a>
                            <a href="#" class="footer__social-link"><img src="~/img/footer/twitter.svg" asp-append-version="true" alt="TW"></a>
                            <a href="#" class="footer__social-link"><img src="~/img/footer/youtube.svg" asp-append-version="true" alt="YT"></a>
                        </div>
                    </div>
                    <p class="footer__description">
                        Createx Construction Bureau успешно работает на строительном рынке США с 2000 года. Мы гордимся тем, что предлагаем вам качественное строительство и образцовый сервис. Наша миссия — устанавливать самые высокие стандарты в строительной сфере.
                    </p>
                </div>
                <div class="footer__column footer__column--subscribe">
                    <h3 class="footer__title">Оставайтесь на связи</h3>
                    <form class="subscribe-form">
                        <input type="email" class="subscribe-form__input" placeholder="Ваш email">
                        <button type="submit" class="subscribe-form__button">ПОДПИСАТЬСЯ</button>
                    </form>
                    <p class="footer__note">*Подпишитесь на нашу рассылку, чтобы получать новости и ранние обновления от Createx Construction Bureau.</p>
                </div>
            </div>

            <div class="footer__middle">
                <div class="footer__column">
                    <h3 class="footer__title">ГЛАВНЫЙ ОФИС</h3>
                    <address class="footer__address">
                        <span><strong>Адрес:</strong> 8502 Preston Rd. Inglewood, New York</span>
                        <span><strong>Телефон:</strong> (405) 555-0128</span>
                        <span><strong>Email:</strong> hello@createx.com</span>
                    </address>
                </div>
                <div class="footer__column">
                    <h3 class="footer__title">О КОМПАНИИ</h3>
                    <nav class="footer__nav">
                        <a asp-page="/AboutUs/About" class="footer__link">О нас</a>
                        <a href="#" class="footer__link">Вакансии</a>
                        <a asp-page="/Contacts/Contacts" class="footer__link">Контакты</a>
                    </nav>
                </div>
                <div class="footer__column">
                    <h3 class="footer__title">НАШ ОПЫТ</h3>
                    <nav class="footer__nav">
                        <a asp-page="/Services/Services" class="footer__link">Услуги</a>
                        <a asp-page="/Work/Work" class="footer__link">Работы</a>
                        <a asp-page="/News/News" class="footer__link">Новости</a>
                    </nav>
                </div>
            </div>

            <div class="footer__bottom">
                <div class="footer__copyright">
                    © Все права защищены. Сделано с <span style="color: #FF5A30;"><img src="~/img/footer/Heart(1).svg" asp-append-version="true" alt="❤"></span> Createx Studio
                </div>
                <a href="#" class="footer__go-top">
                    НАВЕРХ
                    <span class="footer__up-icon"></span>
                </a>
            </div>
        </div>
    </footer>
</body>
</html>