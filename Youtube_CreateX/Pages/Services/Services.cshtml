@page
@model Youtube_CreateX.Pages.Services.ServicesModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Услуги - Createx</title>
    <link rel="stylesheet" href="~/css/services.css" asp-append-version="true">
</head>
<body>

    <div class="top-wrapper">

        <header class="header">
            <div class="container">
                <nav class="header__nav">
                    <a asp-page="/Index" class="header__nav-logo-link">
                        <img src="~/img/header/logo.svg" asp-append-version="true" alt="Логотип Createx" class="header__nav-logo">
                    </a>
                    <ul class="header__nav-ul">
                        <li><a asp-page="/AboutUs/About" class="header__nav-link">О нас</a></li>
                        <li><a asp-page="/Services/Services" class="header__nav-link active">Услуги</a></li>
                        <li><a asp-page="/Work/Work" class="header__nav-link">Работы</a></li>
                        <li><a asp-page="/News/News" class="header__nav-link">Новости</a></li>
                        <li><a asp-page="/Contacts/Contacts" class="header__nav-link">Контакты</a></li>
                    </ul>
                    <div class="header__nav-contacts">
                        <div class="header__nav-contact">
                            <img src="~/img/header/iPhone.svg" asp-append-version="true" alt="Телефон">
                            <div class="contact-text">
                                <div class="label">Позвоните нам</div>
                                <div class="value">(405) 555-0128</div>
                            </div>
                        </div>
                        <div class="header__nav-contact">
                            <img src="~/img/header/Chat.svg" asp-append-version="true" alt="Чат">
                            <div class="contact-text">
                                <div class="label">Напишите нам</div>
                                <div class="value">hello@createx.com</div>
                            </div>
                        </div>
                    </div>
                </nav>
            </div>
        </header>

        <section class="hero">
            <div class="container">
                <ul class="breadcrumbs">
                    <li><a asp-page="/Index">Главная</a></li>
                    <li><span>Услуги</span></li>
                </ul>
                <h1 class="hero__title">УСЛУГИ</h1>
                <p class="hero__desc">
                    Если вы ищете строительную компанию с полным спектром услуг, обратите внимание на Createx Construction Bureau. Мы делаем всё возможное, чтобы стать вашим партнёром во всех строительных вопросах.
                </p>
            </div>
        </section>
    </div>

    <section class="services-section">
        <div class="container">
            <div class="service-item">
                <div class="service-item__image">
                    <img src="~/img/image.svg" asp-append-version="true" alt="Строительство">
                </div>
                <div class="service-item__content">
                    <h2 class="service-item__title">Строительство</h2>
                    <p class="service-item__text">
                        Полный комплекс строительных работ: от возведения жилых и коммерческих зданий до промышленных объектов. Мы используем современные технологии и качественные материалы, гарантируя надёжность и долговечность конструкций.
                    </p>
                    <a href="https://createx.createx.studio/construction/services-single-v1.html" class="btn btn--outline">Подробнее</a>
                </div>
            </div>

            <div class="service-item">
                <div class="service-item__image">
                    <img src="~/img/image(1).svg" asp-append-version="true" alt="Разработка проектов">
                </div>
                <div class="service-item__content">
                    <h2 class="service-item__title">Разработка проектов</h2>
                    <p class="service-item__text">
                        Индивидуальное проектирование зданий и сооружений с учётом всех пожеланий заказчика и требований законодательства. Наши архитекторы и инженеры создают функциональные, безопасные и эстетичные решения.
                    </p>
                    <a href="https://createx.createx.studio/construction/services-single-v1.html" class="btn btn--outline">Подробнее</a>
                </div>
            </div>

            <div class="service-item">
                <div class="service-item__image">
                    <img src="~/img/image(2).svg" asp-append-version="true" alt="Дизайн интерьера">
                </div>
                <div class="service-item__content">
                    <h2 class="service-item__title">Дизайн интерьера</h2>
                    <p class="service-item__text">
                        Создание уникальных интерьеров для жилых и общественных пространств. Мы воплощаем ваши идеи в реальность, подбираем отделочные материалы, мебель и освещение, чтобы каждое помещение было комфортным и стильным.
                    </p>
                    <a href="https://createx.createx.studio/construction/services-single-v2.html" class="btn btn--outline">Подробнее</a>
                </div>
            </div>

            <div class="service-item">
                <div class="service-item__image">
                    <img src="~/img/image(3).svg" asp-append-version="true" alt="Ремонт">
                </div>
                <div class="service-item__content">
                    <h2 class="service-item__title">Ремонт и реконструкция</h2>
                    <p class="service-item__text">
                        Качественный ремонт квартир, офисов и коммерческих помещений. Выполняем все виды работ: от косметического до капитального ремонта, а также реконструкцию зданий с усилением конструкций и перепланировкой.
                    </p>
                    <a href="https://createx.createx.studio/construction/services-single-v2.html" class="btn btn--outline">Подробнее</a>
                </div>
            </div>
        </div>
    </section>

    <section class="discuss">
        <div class="container discuss__container">
            <div class="discuss__card">
                <h2 class="discuss__title">Быстрый способ обсудить детали</h2>
                <form class="discuss__form" method="post">
                    <div class="discuss__field">
                        <label>Имя*</label>
                        <input type="text" placeholder="Ваше имя" required>
                    </div>
                    <div class="discuss__field">
                        <label>Телефон*</label>
                        <input type="tel" placeholder="Ваш номер телефона" required>
                    </div>
                    <div class="discuss__field">
                        <label>Email</label>
                        <input type="email" placeholder="Ваш рабочий email">
                    </div>
                    <div class="discuss__field">
                        <label>Сообщение*</label>
                        <textarea placeholder="Ваше сообщение" required></textarea>
                    </div>
                    <label class="discuss__checkbox">
                        <input type="checkbox" required>
                        <span>Я согласен получать информацию от Createx Construction Bureau.</span>
                    </label>
                    <button type="submit" class="btn btn--fill">ОТПРАВИТЬ ЗАПРОС</button>
                </form>
            </div>
        </div>
    </section>

    <footer class="footer">
        <div class="footer__container">
            <div class="footer__top">
                <div class="footer__column footer__column--info">
                    <div class="footer__brand">
                        <img src="~/img/footer/logo(2).svg" asp-append-version="true" alt="Createx" class="footer__logo">
                        <div class="footer__socials">
                            <a href="#" class="footer__social-link"><img src="~/img/footer/whatsapp.svg" asp-append-version="true" alt="WA"></a>
                            <a href="#" class="footer__social-link"><img src="~/img/footer/Messanger.svg" asp-append-version="true" alt="MS"></a>
                            <a href="#" class="footer__social-link"><img src="~/img/footer/facebook.svg" asp-append-version="true" alt="FB"></a>
                            <a href="#" class="footer__social-link"><img src="~/img/footer/twitter.svg" asp-append-version="true" alt="TW"></a>
                            <a href="#" class="footer__social-link"><img src="~/img/footer/youtube.svg" asp-append-version="true" alt="YT"></a>
                        </div>
                    </div>
                    <p class="footer__description">
                        Createx Construction Bureau успешно работает на строительном рынке США с 2000 года. Мы гордимся тем, что предлагаем вам качественное строительство и образцовый сервис. Наша миссия — устанавливать самые высокие стандарты в строительной сфере.
                    </p>
                </div>
                <div class="footer__column footer__column--subscribe">
                    <h3 class="footer__title">Оставайтесь на связи</h3>
                    <form class="subscribe-form">
                        <input type="email" class="subscribe-form__input" placeholder="Ваш email">
                        <button type="submit" class="subscribe-form__button">ПОДПИСАТЬСЯ</button>
                    </form>
                    <p class="footer__note">*Подпишитесь на нашу рассылку, чтобы получать новости и ранние обновления от Createx Construction Bureau.</p>
                </div>
            </div>

            <div class="footer__middle">
                <div class="footer__column">
                    <h3 class="footer__title">ГЛАВНЫЙ ОФИС</h3>
                    <address class="footer__address">
                        <span><strong>Адрес:</strong> 8502 Preston Rd. Inglewood, New York</span>
                        <span><strong>Телефон:</strong> (405) 555-0128</span>
                        <span><strong>Email:</strong> hello@createx.com</span>
                    </address>
                </div>
                <div class="footer__column">
                    <h3 class="footer__title">О КОМПАНИИ</h3>
                    <nav class="footer__nav">
                        <a asp-page="/AboutUs/About" class="footer__link">О нас</a>
                        <a href="#" class="footer__link">Вакансии</a>
                        <a asp-page="/Contacts/Contacts" class="footer__link">Контакты</a>
                    </nav>
                </div>
                <div class="footer__column">
                    <h3 class="footer__title">НАШ ОПЫТ</h3>
                    <nav class="footer__nav">
                        <a asp-page="/Services/Services" class="footer__link">Услуги</a>
                        <a asp-page="/Work/Work" class="footer__link">Работы</a>
                        <a asp-page="/News/News" class="footer__link">Новости</a>
                    </nav>
                </div>
            </div>

            <div class="footer__bottom">
                <div class="footer__copyright">
                    © Все права защищены. Сделано с <span style="color: #FF5A30;"><img src="~/img/footer/Heart(1).svg" asp-append-version="true" alt="❤"></span> Createx Studio
                </div>
                <a href="#" class="footer__go-top">
                    НАВЕРХ
                    <span class="footer__up-icon"></span>
                </a>
            </div>
        </div>
    </footer>
</body>
</html>