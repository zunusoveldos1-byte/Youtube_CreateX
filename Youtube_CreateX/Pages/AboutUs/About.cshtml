                <p class="statistics__text">Квалифицированных специалистов</p>
            </div>

            <div class="statistics__item">
                <div class="statistics__icon">
                    <img src="~/img/statics/ic-pantone(1).svg" asp-append-version="true" alt="Отделочные работы">
                </div>
                <div class="statistics__value">150 000+ м<sup>2</sup></div>
                <p class="statistics__text">Выполнено отделочных работ</p>
            </div>
