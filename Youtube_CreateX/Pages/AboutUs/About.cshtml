@page
@model Youtube_CreateX.Pages.AboutUs.IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>О нас - Createx</title>
    <link rel="stylesheet" href="~/css/about.css" asp-append-version="true" />
</head>

<body>
    <div class="top-wrapper">

        <header class="header">
            <div class="container">
                <nav class="header__nav">
                    <a asp-page="/Index" class="header__nav-logo-link">
                        <img src="~/img/header/logo(3).svg" asp-append-version="true" alt="Логотип Createx" class="header__nav-logo">
                    </a>
                    <ul class="header__nav-ul">
                        <li><a asp-page="/AboutUs/About" class="header__nav-link active">О нас</a></li>
                        <li><a asp-page="/Services/Services" class="header__nav-link">Услуги</a></li>
                        <li><a asp-page="/Work/Work" class="header__nav-link">Работы</a></li>
                        <li><a asp-page="/News/News" class="header__nav-link">Новости</a></li>
                        <li><a asp-page="/Contacts/Contacts" class="header__nav-link">Контакты</a></li>
                    </ul>
                    <div class="header__nav-contacts">
                        <div class="header__nav-contact">
                            <img src="~/img/header/iPhone(2).svg" asp-append-version="true" alt="Телефон">
                            <div class="contact-text">
                                <div class="label">Позвоните нам</div>
                                <div class="value">(405) 555-0128</div>
                            </div>
                        </div>
                        <div class="header__nav-contact">
                            <img src="~/img/header/Chat(2).svg" asp-append-version="true" alt="Чат">
                            <div class="contact-text">
                                <div class="label">Напишите нам</div>
                                <div class="value">hello@createx.com</div>
                            </div>
                        </div>
                    </div>
                </nav>
            </div>
        </header>

        <section class="hero">
            <div class="container">
                <ul class="breadcrumbs">
                    <li><a asp-page="/Index">Главная</a></li>
                    <li><span>О нас</span></li>
                </ul>
                <h1 class="hero__title">О НАС</h1>
                <p class="hero__desc">
                    Createx Construction Bureau успешно работает на строительном рынке США с 2000 года. Мы гордимся тем, что предлагаем вам качественное строительство и образцовый сервис.
                </p>
            </div>
        </section>
    </div>

    <section class="statistics container">
        <div class="statistics__grid">
            <div class="statistics__item">
                <div class="statistics__icon">
                    <img src="~/img/statics/Vector(1).svg" asp-append-version="true" alt="Клиенты">
                </div>
                <div class="statistics__value">60%</div>
                <p class="statistics__text">Клиентов по рекомендации</p>
            </div>

            <div class="statistics__item">
                <div class="statistics__icon">
                    <img src="~/img/statics/ic-painting(1).svg" asp-append-version="true" alt="Отремонтировано">
                </div>
                <div class="statistics__value">2400+</div>
                <p class="statistics__text">Отремонтированных квартир</p>
            </div>

            <div class="statistics__item">
                <div class="statistics__icon">
                    <img src="~/img/statics/ic-helmet.svg" asp-append-version="true" alt="Специалисты">
                </div>
