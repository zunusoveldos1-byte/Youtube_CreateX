@page
@model Youtube_CreateX.Areas.Admin.Pages.News.IndexModel
@{
    ViewData["Title"] = "Новости";
}
<h1>Новости</h1>
<p>
    <a asp-page="Create" class="btn btn-primary">Добавить новость</a>
</p>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Заголовок</th>
            <th>Категория</th>
            <th>Дата</th>
            <th>Опубликовано</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.NewsList)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Category</td>
                <td>@item.CreatedAt.ToShortDateString()</td>
                <td>@(item.IsPublished ? "Да" : "Нет")</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редактировать</a>
                    <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>