@page
@model Youtube_CreateX.Areas.Admin.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Управление пользователями";
}
<h1>Пользователи</h1>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Email</th>
            <th>Роли</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.Roles</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Редактировать</a>
                    <a asp-page="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>