@page
@model Youtube_CreateX.Areas.Admin.Pages.Services.CreateModel
@{
    ViewData["Title"] = "Добавление услуги";
}
<h1>Добавить услугу</h1>
<form method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Service.Title"></label>
        <input asp-for="Service.Title" class="form-control" />
        <span asp-validation-for="Service.Title" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Service.ShortDescription"></label>
        <textarea asp-for="Service.ShortDescription" class="form-control" rows="2"></textarea>
        <span asp-validation-for="Service.ShortDescription" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Service.FullDescription"></label>
        <textarea asp-for="Service.FullDescription" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Service.FullDescription" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="IconFile">Иконка</label>
        <input asp-for="IconFile" type="file" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Service.DisplayOrder">Порядок отображения</label>
        <input asp-for="Service.DisplayOrder" type="number" class="form-control" />
        <span asp-validation-for="Service.DisplayOrder" class="text-danger"></span>
    </div>
    <div class="form-check">
        <input asp-for="Service.IsPublished" class="form-check-input" />
        <label asp-for="Service.IsPublished">Опубликовать</label>
    </div>
    <button type="submit" class="btn btn-success">Сохранить</button>
    <a asp-page="Index" class="btn btn-secondary">Отмена</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}